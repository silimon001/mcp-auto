        try:
            limit = int(sys.argv[2])
        except ValueError:
            print(f"Invalid limit: {sys.argv[2]}. Using default: {limit}")
    
    result = getEvents(keywords, limit)
    print(json.dumps(result, indent=2, ensure_ascii=False))

