#!/usr/bin/env node
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { createServer } from "./mcp/server.js";
import "./mcp/logging.js";
import { createWebServer } from "./excalidraw/index.js";
async function main() {
    const userServerInfo = await createWebServer("/user/index.html");
    const userTargetUrl = `http://localhost:${userServerInfo.port}`;
    // Set the port as environment variable for the MCP server to use
    process.env.USER_APP_PORT = userServerInfo.port.toString();
    console.log(`✅ User Excalidraw app started on ${userTargetUrl}`);
    console.log(`📊 Open the app to view diagrams: ${userTargetUrl}/user/`);
    const transport = new StdioServerTransport();
    const server = createServer();
    await server.connect(transport);
    // Simple cleanup on exit
    process.on('SIGINT', () => {
        userServerInfo.server.close();
        server.close();
        process.exit(0);
    });
}
main().catch((error) => {
    console.error("Fatal error in main():", error);
    process.exit(1);
});

