    "too-few-public-methods",
    "too-many-arguments",
    "too-many-branches",
    "too-many-instance-attributes",
    "too-many-locals",
    "too-many-nested-blocks",
    "too-many-positional-arguments",
    "too-many-statements",
    "unused-argument",
    "unused-variable",
    "wrong-import-order",
]

[tool.mypy]
python_version = "3.11"

[[tool.mypy.overrides]]
module = [
    "huggingface_hub",
    "open_deep_research",
    "open_deep_research.*",
    "smolagents",
    "yaml",
]
ignore_missing_imports = true

