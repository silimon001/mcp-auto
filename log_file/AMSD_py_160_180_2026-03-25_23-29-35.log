    "open-deep-research @ git+https://github.com/pminervini/open-deep-research.git",
]

[project.scripts]
deep-research-mcp = "deep_research_mcp.mcp_server:main"

[tool.setuptools]
package-dir = { "" = "src" }
include-package-data = true

[tool.setuptools.packages.find]
where = ["src"]

[tool.setuptools.package-data]
deep_research_mcp = ["prompts/**/*.yaml"]

[tool.pylint.main]
fail-under = 10

[tool.pylint.format]
max-line-length = 240

[tool.pylint."messages control"]
disable = [
    "broad-exception-caught",
