    "python-dotenv>=1.0.0",
    "python-json-logger>=2.0.7",
    "pyyaml>=6.0",
    "structlog>=23.1.0",
    "tenacity>=8.2.0",
]

[project.optional-dependencies]
dev = [
    "black>=23.7.0",
    "mypy>=1.5.0",
    "pre-commit>=3.3.0",
    "pylint>=2.17.0",
    "pytest>=7.4.0",
    "pytest-asyncio>=0.21.0",
    "pytest-cov>=4.1.0",
    "pytest-mock>=3.11.0",
]
