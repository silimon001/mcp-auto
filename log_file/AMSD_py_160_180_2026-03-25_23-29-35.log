[build-system]
requires = ["setuptools>=69.0.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "deep-research-mcp"
version = "0.1.0"
description = "MCP server and agent for autonomous deep research workflows"
readme = "README.md"
requires-python = ">=3.11"
license = { file = "LICENSE" }
authors = [{ name = "Deep Research MCP Contributors" }]
dependencies = [
    "aiofiles>=23.2.1",
    "asyncio-throttle>=1.0.2",
    "colorama>=0.4.6",
    "google-genai>=1.55.0",
    "httpx>=0.25.0",
