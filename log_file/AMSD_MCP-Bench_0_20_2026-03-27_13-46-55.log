    for city in test_cities:
        print(f"\nüìç Testing weather for: {city}")
        result = test_mcp_tool("get_current_weather_tool", {"city": city})
        
        if "error" in result:
            print(f"‚ùå Error: {result['error']}")
        else:
            output = result.get("output", result)
            if "error" in output:
